        field { reset = 1'h1; } error_enable[1:1];
        field { reset = 1'h0; } timeout_enable[2:2];
        field { reset = 1'h0; } perf_enable[3:3];
        field { reset = 1'h0; } compl_enable[4:4];
        field { reset = 1'h0; } threshold_enable[5:5];
        field { reset = 1'h0; } debug_enable[6:6];
        field { reset = 16'h0400; } timeout_cycles[31:16];
    } HOST_0_WR_CTRL;

    reg {
        name = "host_0 WR LATENCY";
        field { reset = 32'h00000200; } latency_threshold[31:0];
    } HOST_0_WR_LATENCY;

    reg {
        name = "host_0 WR MASKS_A";
        field { reset = 16'h0000; } axi_pkt_mask[15:0];
