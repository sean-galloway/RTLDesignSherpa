#==============================================================================
# clock_constraint.tcl — dynamic create_clock for the sweep flow
#==============================================================================
# Sourced by create_project.tcl AFTER the static XDC is added.  Emits a
# fresh XDC fragment under build/ with the create_clock constraint using
# the TARGET_PERIOD_NS env var (default 10.0 = 100 MHz).
#
# Letting Vivado STA see a period TIGHTER than the board's actual 100 MHz
# is the cheap way to learn whether the design would close at a given
# target freq.  The bitstream still runs at 100 MHz physically; the WNS
# Vivado reports under the tightened constraint is the spreadsheet-
# calibration signal.
#==============================================================================

set target_period_ns 10.0
if {[info exists ::env(TARGET_PERIOD_NS)] && $::env(TARGET_PERIOD_NS) ne ""} {
    set target_period_ns $::env(TARGET_PERIOD_NS)
}
puts "TARGET_PERIOD_NS:  $target_period_ns"

set half [expr {$target_period_ns / 2.0}]
set dyn_xdc "$project_root/build/timing_target.xdc"
file mkdir [file dirname $dyn_xdc]
set fh [open $dyn_xdc w]
puts $fh "# Auto-generated by clock_constraint.tcl."
puts $fh "# Do not hand-edit; the Makefile sweep regenerates this file."
puts $fh "create_clock -add -name sys_clk_pin -period $target_period_ns \\"
puts $fh "    -waveform {0 $half} \\"
puts $fh "    \[get_ports CLK100MHZ\]"
close $fh

set cf [get_filesets constrs_1]
add_files -norecurse -fileset $cf $dyn_xdc
set_property file_type XDC [get_files -of $cf $dyn_xdc]

puts "  emitted $dyn_xdc"
