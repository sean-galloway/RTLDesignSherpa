//
// {{ bridge_name }}_cfg — auto-generated bridge monitor cfg space.
//
// Generated by bridge_pkg/generators/cfg_rdl_generator.py from the
// adapter list of {{ bridge_name }}. Backed by an AXI4-Lite slave
// (cpuif=axi4-lite-flat); the bridge top instantiates the emitted
// regblock and routes hwif_out fields to its internal cfg_* nets.
//
// Field schema mirrors the bridge generator's MONITOR_CFG_SIGNALS
// list (single source of truth in axi4_timing_wrapper_component.py).
// Per-direction register layout:
//
//   +0x00  CTRL     enables[6:0] + timeout_cycles[31:16]
//   +0x04  LATENCY  latency_threshold[31:0]
//   +0x08  MASKS_A  axi_pkt_mask     + axi_err_select
//   +0x0C  MASKS_B  axi_error_mask   + axi_timeout_mask
//   +0x10  MASKS_C  axi_compl_mask   + axi_thresh_mask
//   +0x14  MASKS_D  axi_perf_mask    + axi_addr_mask
//   +0x18  MASKS_E  axi_debug_mask   (upper 16b reserved)
//
// Conditional clusters:
//   - WINDOW   emitted when the monitor's perf logic is enabled
//   - ADDR_RNG emitted when N_ADDR_RANGES > 0 for that monitor

addrmap {{ bridge_name }}_cfg {
    name = "{{ bridge_name }} monitor cfg";
    desc = "AXIL-mapped cfg backing the bridge's monitor enables, masks, window control, and address-range checker.";

    default regwidth = 32;
    default accesswidth = 32;
    default sw = rw;
    default hw = r;

{% for adapter in adapters %}
{% for dir_lc, dir_uc in [('wr', 'WR'), ('rd', 'RD')] %}
{% if (dir_lc == 'wr' and adapter.has_wr) or (dir_lc == 'rd' and adapter.has_rd) %}
    // ----------------------------------------------------------------
    // {{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} direction
    // ----------------------------------------------------------------
    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} CTRL";
        desc = "Per-cone enables (bits [6:0]) and timeout_cycles (bits [31:16]).";
        field { reset = 1'h1; } monitor_enable[0:0];
        field { reset = 1'h1; } error_enable[1:1];
        field { reset = 1'h0; } timeout_enable[2:2];
        field { reset = 1'h0; } perf_enable[3:3];
        field { reset = 1'h0; } compl_enable[4:4];
        field { reset = 1'h0; } threshold_enable[5:5];
        field { reset = 1'h0; } debug_enable[6:6];
        field { reset = 16'h0400; } timeout_cycles[31:16];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_CTRL;

    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} LATENCY";
        field { reset = 32'h00000200; } latency_threshold[31:0];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_LATENCY;

    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} MASKS_A";
        field { reset = 16'h0000; } axi_pkt_mask[15:0];
        field { reset = 16'h0000; } axi_err_select[31:16];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_MASKS_A;

    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} MASKS_B";
        field { reset = 16'h0000; } axi_error_mask[15:0];
        field { reset = 16'h0000; } axi_timeout_mask[31:16];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_MASKS_B;

    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} MASKS_C";
        field { reset = 16'h0000; } axi_compl_mask[15:0];
        field { reset = 16'h0000; } axi_thresh_mask[31:16];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_MASKS_C;

    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} MASKS_D";
        field { reset = 16'h0000; } axi_perf_mask[15:0];
        field { reset = 16'h0000; } axi_addr_mask[31:16];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_MASKS_D;

    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} MASKS_E";
        field { reset = 16'h0000; } axi_debug_mask[15:0];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_MASKS_E;

{% if adapter.perfmon_enabled %}
    // Window cfg — present because the monitor enables the perf cone.
    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} WINDOW_CTRL";
        desc = "Stage A window-trigger config.";
        field { reset = 3'b111; } start_event_sel[2:0];   // never-fire
        field { reset = 3'b111; } end_event_sel[5:3];     // never-fire
        field { reset = 1'b0;   } start_trigger[6:6];
        field { reset = 1'b0;   } end_trigger[7:7];
        field { reset = 1'b0;   } window_force_close[8:8];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_WINDOW_CTRL;

{% endif %}
{% if adapter.n_addr_ranges > 0 %}
    // Address-range checker — N_ADDR_RANGES={{ adapter.n_addr_ranges }}.
    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} ADDR_CHECK";
        field { reset = 1'b0; } addr_check_enable[0:0];
        field { reset = {{ adapter.n_addr_ranges }}'b0; } addr_range_enable[{{ adapter.n_addr_ranges }}:1];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_ADDR_CHECK;

{% for r in range(adapter.n_addr_ranges) %}
    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} ADDR_RANGE_{{ r }}_LO";
        field { reset = 32'h00000000; } addr_low[{{ adapter.addr_width - 1 }}:0];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_ADDR_RANGE_{{ r }}_LO;

    reg {
        name = "{{ adapter.name }}_{{ adapter.idx }} {{ dir_uc }} ADDR_RANGE_{{ r }}_HI";
        field { reset = 32'h00000000; } addr_high[{{ adapter.addr_width - 1 }}:0];
    } {{ adapter.name | upper }}_{{ adapter.idx }}_{{ dir_uc }}_ADDR_RANGE_{{ r }}_HI;

{% endfor %}
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}
    // ----------------------------------------------------------------
    // Group cfg — shared across all monitors at the monbus_axil_group.
    // Emitted from the bridge generator's _MON_GROUP_CFG tuple: 32-bit
    // fields each get their own MON_GROUP_<NAME> register; 16-bit
    // mask fields are packed two per register as MON_GROUP_PACK_<N>.
    // ----------------------------------------------------------------
{% for entry in group_regs %}
    reg {
        name = "{{ entry.reg }}";
        desc = "{{ entry.desc }}";
{% if entry.width == 32 %}
        field { reset = 32'h00000000; } {{ entry.field }}[31:0];
{% else %}
{% for f in entry.fields %}
        field { reset = 16'h0000; } {{ f.name }}[{{ f.hi }}:{{ f.lo }}];
{% endfor %}
{% endif %}
    } {{ entry.reg }};

{% endfor %}
};
