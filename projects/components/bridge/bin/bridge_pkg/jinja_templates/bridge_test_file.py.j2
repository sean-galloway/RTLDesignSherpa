@cocotb.test(timeout_time=200, timeout_unit="ms")
async def cocotb_test_basic_connectivity(dut):
    """
    Basic connectivity — every (master, slave) pair gets one write and/or
    one read at a non-base offset inside the slave's window. Reads check
    against the pre-seeded slave memory pattern; writes verify the bytes
    landed in the slave's memory at the expected offset.

    The slave BFMs auto-respond from their MemoryModel honoring whatever
    ARSIZE/ARLEN/ARADDR (or AWSIZE/AWLEN/AWADDR) the bridge forwards, so
    the same test body works across direct, width-converted, and
    AXIL-shimmed paths — the bridge moves bytes, we read the bytes back.
    """
    tb = {{ tb_class_name }}(dut)
    await tb.setup_clocks_and_reset()

    tb.log.info("=" * 80)
    tb.log.info("Starting basic connectivity test")
    tb.log.info(f"Configuration: {{ num_masters }}M x {{ num_slaves }}S, {{ channel_type.upper() }} channels")
    tb.log.info("=" * 80)

{% if channel_type == 'wr' or channel_type == 'rw' %}
    # ---- Write connectivity --------------------------------------------
{% for master_idx in range(num_masters) %}
{% set master = masters[master_idx] %}
{% if master.has_write_channels() %}
    tb.log.info(f"Master {{ master_idx }} ({{ master.port_name }}) — writes")
{% for slave in slaves %}
{% if slave.port_name in connectivity.get(master.port_name, []) %}
{% if slave.has_write_channels() %}
    # Master {{ master_idx }} → Slave {{ loop.index0 }} ({{ slave.port_name }})
    test_addr = {{ '0x%08x' % (slave.base_addr + 0x100) }}
    # Non-pattern data: upper byte 0xDE so it can't be confused with any
    # slave's seed pattern (which uses 0x01..0xFF in the upper byte for
    # the slave ID). Lower byte tags the (master, slave) pair for debug.
    test_data = (0xDE000000 | ({{ master_idx }} << 12) | {{ loop.index0 }})
    tb.log.info(f"  W slave={{ loop.index0 }} addr=0x{test_addr:08x} data=0x{test_data:08x}")
    await tb.master_write({{ master_idx }}, test_addr, test_data)
    await tb.expect_aw_at_slave({{ loop.index0 }}, test_addr)
    # Read back at master {{ master_idx }}'s width — only the bytes the master
    # actually wrote should be compared; trailing bytes are still the seed.
    actual = tb.slave_mem_read({{ loop.index0 }}, test_addr, master_idx={{ master_idx }})
    assert actual == test_data, (
        f"Slave {{ loop.index0 }} memory mismatch at 0x{test_addr:08x}: "
        f"got 0x{actual:08x}, expected 0x{test_data:08x}")
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

{% if channel_type == 'rd' or channel_type == 'rw' %}
    # ---- Read connectivity ---------------------------------------------
{% for master_idx in range(num_masters) %}
{% set master = masters[master_idx] %}
{% if master.has_read_channels() %}
    tb.log.info(f"Master {{ master_idx }} ({{ master.port_name }}) — reads")
{% for slave in slaves %}
{% if slave.port_name in connectivity.get(master.port_name, []) %}
{% if slave.has_read_channels() %}
    # Master {{ master_idx }} → Slave {{ loop.index0 }} ({{ slave.port_name }})
    # Probe a non-base offset; addr_range is 4 KB-aligned by validator so
    # +0x100 is always safely inside the slave's window.
    test_addr = {{ '0x%08x' % (slave.base_addr + 0x100) }}
    expected = tb.slave_mem_read({{ loop.index0 }}, test_addr, master_idx={{ master_idx }})
    tb.log.info(f"  R slave={{ loop.index0 }} addr=0x{test_addr:08x} expect=0x{expected:08x}")
    actual = await tb.master_read({{ master_idx }}, test_addr)
    await tb.expect_ar_at_slave({{ loop.index0 }}, test_addr)
    assert actual == expected, (
        f"Read mismatch master {{ master_idx }} ← slave {{ loop.index0 }} at 0x{test_addr:08x}: "
        f"got 0x{actual:08x}, expected 0x{expected:08x} (seeded pattern)")
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

    await ClockCycles(tb.clock, 20)
    tb.log.info("=" * 80)
    tb.log.info("Basic connectivity test PASSED")
    tb.log.info("=" * 80)


@cocotb.test(timeout_time=500, timeout_unit="ms")
async def cocotb_test_address_decode(dut):
    """
    Address decode — for each (master, slave) pair, probe the first and
    last word of the slave's window to catch decoders that ignore high or
    low address bits.
    """
    tb = {{ tb_class_name }}(dut)
    await tb.setup_clocks_and_reset()

    tb.log.info("=" * 80)
    tb.log.info("Starting address decode test")
    tb.log.info("=" * 80)

{% for master_idx in range(num_masters) %}
{% set master = masters[master_idx] %}
{% if master.has_write_channels() or master.has_read_channels() %}
    tb.log.info(f"Master {{ master_idx }} ({{ master.port_name }})")
{% for slave in slaves %}
{% if slave.port_name in connectivity.get(master.port_name, []) %}
    # Slave {{ loop.index0 }} ({{ slave.port_name }}): 0x{{ '%08x' % slave.base_addr }}-0x{{ '%08x' % (slave.base_addr + slave.addr_range - 1) }}
    base_addr = {{ '0x%08x' % slave.base_addr }}
    # Probe the end of the *seeded* region (MemoryModel is capped to
    # SLAVE_MEM_CAP_BYTES — the slave's natural addr_range can be GBs).
    # The end-address has to be aligned to max(master_width, slave_width)
    # because the dwidth converter for upsize reads (narrow master, wide
    # slave) down-aligns ARADDR to the wide-beat boundary; an unaligned
    # probe would silently return bytes from a different memory offset
    # than slave_mem_read predicts.
    master_bytes_{{ master_idx }} = tb.master_data_width[{{ master_idx }}] // 8
    slave_bytes_{{ loop.index0 }} = {{ slave.data_width }} // 8
    align_bytes = max(master_bytes_{{ master_idx }}, slave_bytes_{{ loop.index0 }})
    end_addr  = base_addr + tb._slave_mem_bytes({{ loop.index0 }}) - align_bytes
{% if master.has_write_channels() and slave.has_write_channels() %}
    # Boundary write — base
    d0 = (0xDE000000 | ({{ master_idx }} << 12) | ({{ loop.index0 }} << 4) | 0x0)
    await tb.master_write({{ master_idx }}, base_addr, d0)
    assert tb.slave_mem_read({{ loop.index0 }}, base_addr, master_idx={{ master_idx }}) == d0
    # Boundary write — end
    d1 = (0xDE000000 | ({{ master_idx }} << 12) | ({{ loop.index0 }} << 4) | 0x1)
    await tb.master_write({{ master_idx }}, end_addr, d1)
    assert tb.slave_mem_read({{ loop.index0 }}, end_addr, master_idx={{ master_idx }}) == d1
{% elif master.has_read_channels() and slave.has_read_channels() %}
    # Boundary read — base
    exp0 = tb.slave_mem_read({{ loop.index0 }}, base_addr, master_idx={{ master_idx }})
    got0 = await tb.master_read({{ master_idx }}, base_addr)
    assert got0 == exp0, f"slave {{ loop.index0 }} base mismatch: got 0x{got0:08x}, exp 0x{exp0:08x}"
    # Boundary read — end
    exp1 = tb.slave_mem_read({{ loop.index0 }}, end_addr, master_idx={{ master_idx }})
    got1 = await tb.master_read({{ master_idx }}, end_addr)
    assert got1 == exp1, f"slave {{ loop.index0 }} end mismatch: got 0x{got1:08x}, exp 0x{exp1:08x}"
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}

    await ClockCycles(tb.clock, 20)
    tb.log.info("=" * 80)
    tb.log.info("Address decode test PASSED")
    tb.log.info("=" * 80)


