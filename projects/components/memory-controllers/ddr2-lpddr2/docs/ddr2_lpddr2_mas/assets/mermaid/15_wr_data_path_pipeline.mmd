%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e8f4e8', 'primaryTextColor': '#000', 'primaryBorderColor': '#228B22', 'lineColor': '#404040', 'secondaryColor': '#f0f0f0', 'tertiaryColor': '#fff'}}}%%
flowchart LR
    subgraph AXI["axi4_slave_fub"]
        w_buf["w_buf<br/>(AXI W beat data +<br/> wstrb + wlast)"]
        wr_cam["wr_cmd_cam<br/>beat_pull strobe<br/>(per slot,<br/> emits beat_pull_ptr,<br/> beat_pull_strb,<br/> beat_pull_last)"]
    end

    subgraph WRP["wr_data_path_fub (streaming pipeline; NO FSM)"]
        pull_ptr["pull_ptr register<br/>(advances on each<br/> beat_pull_strobe)"]
        wbuf_read["w_buf combinational read<br/>at beat_pull_ptr<br/>(no read-port FSM,<br/> async memory read)"]
        width_conv["Width converter<br/>(AXI_DW -> DFI_DW × NP)<br/>shift-register pipeline,<br/> pure combinational+regs;<br/> NO sequence FSM"]
        beat_align["CWL-align flag<br/>(small shift register<br/> from scheduler WR/WRA<br/> issue strobe)"]
        beat_pipe["one-beat-per-MC-cycle<br/>output register<br/>(wr_beat_data,<br/> wr_beat_mask,<br/> wr_beat_valid)"]
    end

    subgraph GEAR["gear_dfi_fub"]
        wr_lane["routes beat to<br/>WRPHASE slot"]
    end

    sched_strb["scheduler WR/WRA<br/>issue strobe"]

    sched_strb --> beat_align
    w_buf --> wbuf_read
    wr_cam --> pull_ptr
    pull_ptr --> wbuf_read
    wbuf_read --> width_conv
    width_conv --> beat_pipe
    beat_align --> beat_pipe
    beat_pipe --> wr_lane

    classDef axiblock fill:#f0f0f0,stroke:#666666,stroke-width:2px
    classDef wrpblock fill:#e8f4e8,stroke:#228B22,stroke-width:2px
    classDef gearblock fill:#e0e8fa,stroke:#3366CC,stroke-width:2px
    classDef cmdblock fill:#fef0e0,stroke:#B88B22,stroke-width:2px

    class w_buf,wr_cam axiblock
    class pull_ptr,wbuf_read,width_conv,beat_align,beat_pipe wrpblock
    class wr_lane gearblock
    class sched_strb cmdblock
