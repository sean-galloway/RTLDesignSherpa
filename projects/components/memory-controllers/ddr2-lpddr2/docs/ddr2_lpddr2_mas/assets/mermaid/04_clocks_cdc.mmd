flowchart LR
    subgraph APB_DOM["apb_pclk domain (25–100 MHz)"]
        apb_proto["APB3 protocol engine"]
        apb_staging["staging registers<br/>(per R/W field)"]
        apb_read_sync["read-side<br/>Gray-decode"]
    end

    subgraph CDC["CDC (in csr_apb_fub)"]
        wr_sync["write-side<br/>4-flop sync<br/>+ edge detect"]
        rd_sync["read-side<br/>pulse-sync<br/>+ Gray counter"]
    end

    subgraph MC_DOM["mc_clk domain (100–500 MHz)"]
        live_regs["live CSR cells"]
        quiet_pt["quiet_point detector<br/>(power_state_fub)"]
        commit["commit-on-quiet-point<br/>(staging → live)"]
        obs_cnt["observation counters<br/>(rolling, gray-coded)"]
        live_datapath["live datapath<br/>(scheduler, refresh, etc.)"]
    end

    APB[/"APB master"/] --> apb_proto
    apb_proto --> apb_staging
    apb_staging --> wr_sync
    wr_sync --> commit
    quiet_pt --> commit
    commit --> live_regs
    live_regs --> live_datapath

    live_datapath --> obs_cnt
    obs_cnt --> rd_sync
    rd_sync --> apb_read_sync
    apb_read_sync --> apb_proto
    apb_proto --> APB

    classDef apb fill:#f0f0f0,stroke:#666666,stroke-width:2px
    classDef cdc fill:#fef0e0,stroke:#B88B22,stroke-width:2px
    classDef mc fill:#e8f4e8,stroke:#228B22,stroke-width:2px

    class apb_proto,apb_staging,apb_read_sync apb
    class wr_sync,rd_sync cdc
    class live_regs,quiet_pt,commit,obs_cnt,live_datapath mc
