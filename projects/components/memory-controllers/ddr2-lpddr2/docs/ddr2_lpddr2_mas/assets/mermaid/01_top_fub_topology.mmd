%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e8f4e8', 'primaryTextColor': '#000', 'primaryBorderColor': '#228B22', 'lineColor': '#404040', 'secondaryColor': '#f0f0f0', 'tertiaryColor': '#fff'}}}%%
flowchart TB
    subgraph TOP["ddr2_lpddr2_ctrl (rtl/top)"]

        subgraph FRONT["AXI Frontend"]
            axi4_slave["axi4_slave_fub"]
            addr_mapper["addr_mapper_fub<br/>(XOR / scheme mux,<br/>combinational)"]
            rd_cam["rd_cmd_cam_fub<br/>(reads)"]
            wr_cam["wr_cmd_cam_fub<br/>(writes)"]
        end

        subgraph SCHED["Buffering + Scheduling"]
            txn_queue["txn_queue_fub"]
            scheduler["scheduler_fub<br/>(FR-FCFS)"]
            page_predictor["page_predictor_fub<br/>(HAPPY, optional)"]
        end

        subgraph BANKS["Per-(rank,bank) State + Timing"]
            bank_machines["bank_machine_fub<br/>[NUM_RANKS × NUM_BANKS]"]
            xbank_timers["xbank_timers_fub<br/>(tRRD/tFAW per-rank,<br/>tCCD/tWTR global)"]
        end

        subgraph REFPWR["Refresh / Init / Power"]
            refresh_mgr["refresh_mgr_fub<br/>(REFab round-robin,<br/>REFpb DARP)"]
            init_engine["init_engine_fub"]
            power_state["power_state_fub<br/>(+ quiet-point)"]
        end

        subgraph ENC["Encoding + Output Gear"]
            cmd_encoder["cmd_encoder_fub<br/>(DDR2 ras/cas/we OR<br/>LPDDR2 CA bus)"]
            gear_dfi["gear_dfi_fub<br/>(1 → N_PHASES)"]
            odt_ctrl["odt_ctrl_fub<br/>(per-rank ODT)"]
        end

        subgraph DATA["Data Paths"]
            wr_data["wr_data_path_fub"]
            rd_data["rd_data_path_fub"]
        end

        subgraph CFG["Configuration"]
            csr_apb["csr_apb_fub<br/>(apb_pclk → mc_clk CDC)"]
        end

    end

    AXI[/"AXI4 Slave Port<br/>(host)"/] --> axi4_slave
    axi4_slave --> addr_mapper
    addr_mapper --> rd_cam
    addr_mapper --> wr_cam
    rd_cam --> txn_queue
    wr_cam --> txn_queue
    txn_queue --> scheduler
    scheduler <--> page_predictor
    scheduler <--> bank_machines
    bank_machines <--> xbank_timers
    refresh_mgr <--> bank_machines
    refresh_mgr --> scheduler
    init_engine --> scheduler
    power_state --> scheduler
    refresh_mgr --> power_state
    scheduler --> cmd_encoder
    cmd_encoder --> gear_dfi
    odt_ctrl --> gear_dfi
    power_state --> odt_ctrl
    wr_data --> gear_dfi
    gear_dfi --> rd_data
    axi4_slave --> wr_data
    rd_data --> axi4_slave
    rd_cam -.completion.-> axi4_slave
    wr_cam -.completion.-> axi4_slave
    gear_dfi --> DFI[/"DFI v2.1 Master Port<br/>(to PHY)"/]
    csr_apb -.config.-> scheduler
    csr_apb -.config.-> refresh_mgr
    csr_apb -.config.-> addr_mapper
    csr_apb -.config.-> power_state
    csr_apb -.config.-> odt_ctrl
    APB[/"APB CSR Slave Port<br/>(config)"/] --> csr_apb

    classDef frontend fill:#e8f4e8,stroke:#228B22,stroke-width:2px
    classDef sched fill:#f0e8f4,stroke:#7B228B,stroke-width:2px
    classDef banks fill:#fef0e0,stroke:#B88B22,stroke-width:2px
    classDef refpwr fill:#e0e8fa,stroke:#3366CC,stroke-width:2px
    classDef enc fill:#fae0e0,stroke:#CC3322,stroke-width:2px
    classDef data fill:#e8fae0,stroke:#558B22,stroke-width:2px
    classDef cfg fill:#f0f0f0,stroke:#666666,stroke-width:2px

    class axi4_slave,addr_mapper,rd_cam,wr_cam frontend
    class txn_queue,scheduler,page_predictor sched
    class bank_machines,xbank_timers banks
    class refresh_mgr,init_engine,power_state refpwr
    class cmd_encoder,gear_dfi,odt_ctrl enc
    class wr_data,rd_data data
    class csr_apb cfg
