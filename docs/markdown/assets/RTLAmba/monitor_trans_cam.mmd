        MATCH["Parallel one-hot match<br/>(* keep = 'true' *)<br/>1 LUT/bit/port"]

        FREE["free_oh = ~r_valid"]

        ALLOC["3-way mutex<br/>priority encoder<br/>(addr → data → resp)"]
